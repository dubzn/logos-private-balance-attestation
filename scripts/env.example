# Example local environment for LP-0005 development.
#
# Recommended public/evaluator layout:
#
#   workdir/
#     logos-private-balance-attestation/
#     logos-execution-zone/
#
# From the attestation repo root, source this file and replace LOGOS_LEZ_REPO
# if your LEZ fork lives somewhere else:
#
#   source scripts/env.example

export LOGOS_LEZ_REPO="${LOGOS_LEZ_REPO:-$(pwd)/../logos-execution-zone}"
export LEZ_REPO="$LOGOS_LEZ_REPO"
export NSSA_WALLET_HOME_DIR="${NSSA_WALLET_HOME_DIR:-$LOGOS_LEZ_REPO/.wallet-local}"

# Dev mode is fast but not cryptographically valid. Use 0 for final demos.
export RISC0_DEV_MODE="${RISC0_DEV_MODE:-0}"
